# Environment Variables

PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://your_mongo_uri
MONGODB_DB_NAME=your_db_name
CORS_ORIGINS=http://your_origin
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
BCRYPT_SALT_ROUNDS=10
SEED_ADMIN_PASSWORD=your_seed_admin_password
SEED_MANAGER_PASSWORD=your_seed_manager_password
GEMINI_API_KEY=your_gemini_api_key
MAIL_USE_ETHEREAL=true
MAIL_HOST=your_mail_host
MAIL_PORT=587
MAIL_USER=your_mail_user
MAIL_PASS=your_mail_password
MAIL_FROM_NAME=Your App
MAIL_FROM_ADDRESS=no-reply@your_domain

# ===== Payments =====

# VNPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_SECURE_SECRET=your_vnpay_secure_secret
VNPAY_RETURN_URL="http://localhost:5000/api/v1/payments/vnpay-return"
VNPAY_HOST="https://sandbox.vnpayment.vn"
VNPAY_TEST_MODE="true"
VNPAY_HASH_ALGORITHM="SHA512"
VNPAY_ENABLE_LOG="false"

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_API_BASE_URL="https://api-m.sandbox.paypal.com"